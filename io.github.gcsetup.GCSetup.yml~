app-id: io.github.gcsetup.GCSetup
runtime: org.gnome.Platform
runtime-version: '47'
sdk: org.gnome.Sdk
command: gc-setup

finish-args:
  # Network access — needed to install Flatpaks, download extensions & AppImages
  - --share=network
  # Display
  - --socket=wayland
  - --socket=fallback-x11
  # GPU acceleration for GTK rendering
  - --device=dri
  # Talk to Flatpak system service — needed for flatpak-spawn --host
  - --talk-name=org.freedesktop.Flatpak
  # Access to host commands via flatpak-spawn
  - --talk-name=org.freedesktop.impl.portal.PermissionStore
  # Needed for clipboard (copy commands in misc section)
  - --share=ipc

modules:
  - name: gc-setup
    buildsystem: meson
    sources:
      - type: dir
        path: .
