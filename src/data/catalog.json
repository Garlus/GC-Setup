    {
      "id": "system-tweaks",
      "name": "System Tweaks",
      "icon": "preferences-other-symbolic",
      "items": [
        {
          "name": "Full System Update",
          "description": "Update all system packages and Flatpaks to their latest versions",
          "install": {
            "method": "system",
            "commands": {
              "apt": "sudo apt update && sudo apt upgrade -y && flatpak update -y",
              "dnf": "sudo dnf upgrade -y && flatpak update -y",
              "pacman": "sudo pacman -Syu --noconfirm && flatpak update -y",
              "zypper": "sudo zypper ref && sudo zypper --non-interactive dup && flatpak update -y"
            }
          },
          "detect": {}
        },
        {
          "name": "Full System Cleanup",
          "description": "Remove unnecessary packages, clean old caches, truncate logs, and empty the trash",
          "install": {
            "method": "system",
            "commands": {
              "apt": "sudo apt autoremove -y && sudo apt clean && sudo journalctl --vacuum-time=3d && find ~/.cache/ -type f -atime +5 -delete 2>/dev/null; find ~/.local/share/Trash -mindepth 1 -delete 2>/dev/null; echo 'Cleanup complete'",
              "dnf": "sudo dnf autoremove -y && sudo dnf clean all && sudo journalctl --vacuum-time=3d && find ~/.cache/ -type f -atime +5 -delete 2>/dev/null; find ~/.local/share/Trash -mindepth 1 -delete 2>/dev/null; echo 'Cleanup complete'",
              "pacman": "sudo pacman -Sc --noconfirm && sudo pacman -Rns $(pacman -Qtdq) --noconfirm 2>/dev/null; sudo journalctl --vacuum-time=3d && find ~/.cache/ -type f -atime +5 -delete 2>/dev/null; find ~/.local/share/Trash -mindepth 1 -delete 2>/dev/null; echo 'Cleanup complete'",
              "zypper": "sudo zypper clean --all && sudo journalctl --vacuum-time=3d && find ~/.cache/ -type f -atime +5 -delete 2>/dev/null; find ~/.local/share/Trash -mindepth 1 -delete 2>/dev/null; echo 'Cleanup complete'"
            }
          },
          "detect": {}
        },
        {
          "name": "Virtualization (QEMU/KVM)",
          "description": "Install QEMU, libvirt, and Virt-Manager for running virtual machines",
          "install": {
            "method": "system",
            "commands": {
              "apt": "sudo apt install -y qemu-system-x86 libvirt-daemon-system libvirt-clients virt-manager bridge-utils dnsmasq && sudo systemctl enable --now libvirtd && sudo usermod -aG libvirt $USER",
              "dnf": "sudo dnf install -y @virtualization && sudo systemctl enable --now libvirtd && sudo usermod -aG libvirt $USER",
              "pacman": "sudo pacman -S --noconfirm qemu-desktop libvirt virt-manager dnsmasq iptables-nft dmidecode && sudo systemctl enable --now libvirtd && sudo usermod -aG libvirt $USER && sudo usermod -aG kvm $USER",
              "zypper": "sudo zypper install -y qemu-kvm libvirt virt-manager dnsmasq && sudo systemctl enable --now libvirtd && sudo usermod -aG libvirt $USER"
            }
          },
          "detect": { "command": "virt-manager" }
        },
        {
          "name": "TTY Fonts (Terminus)",
          "description": "Install Terminus console font and set it as the default TTY font for better readability",
          "install": {
            "method": "system",
            "commands": {
              "apt": "sudo apt install -y fonts-terminus && sudo sed -i 's/^FONTFACE=.*/FONTFACE=\"TerminusBold\"/' /etc/default/console-setup && sudo sed -i 's/^FONTSIZE=.*/FONTSIZE=\"10x18\"/' /etc/default/console-setup && sudo update-initramfs -u",
              "dnf": "sudo dnf install -y terminus-fonts-console && sudo sed -i 's/^FONT=.*/FONT=ter-v18b/' /etc/vconsole.conf",
              "pacman": "sudo pacman -S --noconfirm terminus-font && sudo sed -i 's/^FONT=.*/FONT=ter-v18b/' /etc/vconsole.conf",
              "zypper": "sudo zypper install -y terminus-bitmap-fonts && sudo sed -i 's/^FONT=.*/FONT=ter-v18b/' /etc/vconsole.conf"
            }
          },
          "detect": {}
        },
        {
          "name": "Microsoft Fonts",
          "description": "Core Microsoft TrueType fonts (Arial, Times New Roman, etc.)",
          "install": {
            "method": "system",
            "commands": {
              "apt": "sudo apt install -y ttf-mscorefonts-installer",
              "dnf": "sudo dnf install -y curl cabextract xorg-x11-font-utils fontconfig && sudo rpm -i https://downloads.sourceforge.net/project/mscorefonts2/rpms/msttcore-fonts-installer-2.6-1.noarch.rpm",
              "pacman": "yay -S --noconfirm ttf-ms-fonts || paru -S --noconfirm ttf-ms-fonts",
              "zypper": "sudo zypper install -y fetchmsttfonts"
            }
          },
          "detect": { "command": "fc-match" }
        },
        {
          "name": "Common Codecs",
          "description": "GStreamer multimedia codecs for video and audio playback",
          "install": {
            "method": "system",
            "commands": {
              "apt": "sudo apt install -y gstreamer1.0-plugins-good gstreamer1.0-plugins-bad gstreamer1.0-plugins-ugly gstreamer1.0-libav",
              "dnf": "sudo dnf install -y gstreamer1-plugins-good gstreamer1-plugins-bad-free gstreamer1-plugins-ugly gstreamer1-plugins-bad-freeworld gstreamer1-plugin-libav",
              "pacman": "sudo pacman -S --noconfirm gst-plugins-good gst-plugins-bad gst-plugins-ugly gst-libav",
              "zypper": "sudo zypper install -y gstreamer-plugins-good gstreamer-plugins-bad gstreamer-plugins-ugly gstreamer-plugins-libav"
            }
          },
          "detect": {}
